# Supabase REST API credentials (for supabase-py client)
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# Supabase Postgres Connection Pooler URL (if you plan to use asyncpg, SQLAlchemy, etc.)
# You can find this in your Supabase Dashboard under Settings > Database > Connection pooler
DATABASE_URL=postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true


# Neon DB (ephemeral data: thought logs, scan jobs)
NEON_DSN=postgresql://user:password@host/neondb?sslmode=require

# Groq API Key (for AgentField LLM interactions)
GROQ_API_KEY=your-groq-api-key
